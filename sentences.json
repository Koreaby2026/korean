[{"kr":"시계가 너무 비싸요.","rom":"sigyega neomu bissayo.","en":"The clock is too expensive.","vocab":["시계","너무","비싸다"]},{"kr":"어디에 화장실이 있어요?","rom":"eodie hwajangsiri isseoyo?","en":"Where is the bathroom?","vocab":["어디","화장실"]},{"kr":"오늘 학교에 가요.","rom":"oneul hakgyoe gayo.","en":"Today I go to school.","vocab":["학교"]},{"kr":"지난 주말에 영화를 봤어요.","rom":"jinan jumare yeonghwareul bwasseoyo.","en":"Last weekend I watched a movie.","vocab":["지난"]},{"kr":"여름이 더워서 수박을 먹어요.","rom":"yeoreumi deowoseo subageul meogeoyo.","en":"Because summer is hot, I eat watermelon.","vocab":["여름","덥다","수박"]},{"kr":"겨울에는 눈이 와요.","rom":"gyeoureneun nuni wayo.","en":"In winter, it snows.","vocab":["겨울","눈이 오다"]},{"kr":"친구하고 같이 등산을 해요.","rom":"chinguhago gachi deungsaneul haeyo.","en":"I go hiking with a friend.","vocab":["등산을 하다"]},{"kr":"내일 시험이 있어서 바빠요.","rom":"naeil siheomi isseoseo bappayo.","en":"I have an exam tomorrow, so I'm busy.","vocab":["시험","바쁘다"]},{"kr":"지금 너무 피곤해요.","rom":"jigeum neomu pigonhaeyo.","en":"I'm very tired now.","vocab":["너무","피곤하다"]},{"kr":"한국 음식을 좋아해요.","rom":"hanguk eumsigeul joahaeyo.","en":"I like Korean food.","vocab":["음식"]},{"kr":"이 옷은 너무 비싸요. 더 싼 거 있어요?","rom":"i oseun neomu bissayo. deo ssan geo isseoyo?","en":"These clothes are too expensive. Is there something cheaper?","vocab":["너무","비싸다","싸다"]},{"kr":"매일 아침 일찍 일어나요.","rom":"maeil achim iljjik ireonayo.","en":"I get up early every morning.","vocab":["매일","아침","일찍"]},{"kr":"비가 와서 집에 있어요.","rom":"biga waseo jibe isseoyo.","en":"It's raining, so I'm at home.","vocab":["비가 오다"]},{"kr":"주말에 보통 무엇을 해요?","rom":"jumare botong mueoseul haeyo?","en":"What do you usually do on weekends?","vocab":["보통","무엇"]},{"kr":"어떻게 학교에 가요?","rom":"eotteoke hakgyoe gayo?","en":"How do you go to school?","vocab":["어떻게","학교"]},{"kr":"저는 한국어를 조금 알아요.","rom":"jeoneun hangugeoreul jogeum arayo.","en":"I know a little Korean.","vocab":["조금"]},{"kr":"약속이 있어서 일찍 가야 해요.","rom":"yaksogi isseoseo iljjik gaya haeyo.","en":"I have an appointment, so I have to leave early.","vocab":["약속","일찍"]},{"kr":"기차역이 어디에 있어요?","rom":"gichayeogi eodie isseoyo?","en":"Where is the train station?","vocab":["기차역","어디"]},{"kr":"선물을 받아서 기분이 좋아요.","rom":"seonmureul badaseo gibuni joayo.","en":"I got a gift, so I'm in a good mood.","vocab":["선물","받다","기분"]},{"kr":"사진을 찍는 것을 좋아해요.","rom":"sajineul jjikneun geoseul joahaeyo.","en":"I like taking photos.","vocab":["사진을 찍다"]},{"kr":"낚시는 제 취미예요.","rom":"naksineun je chwimiyeyo.","en":"Fishing is my hobby.","vocab":["낚시","취미"]},{"kr":"오늘은 무슨 요일이에요?","rom":"oneureun museun yoirieyo?","en":"What day of the week is it today?","vocab":["무슨","요일"]},{"kr":"저는 일주일에 한 번 운동해요.","rom":"jeoneun iljuire han beon undonghaeyo.","en":"I exercise once a week.","vocab":["일주일에 한 번"]},{"kr":"친구를 두 시간 동안 기다렸어요.","rom":"chingureul du sigan dongan gidaryeosseoyo.","en":"I waited two hours for my friend.","vocab":["기다리다"]},{"kr":"이 노래가 가장 좋아요.","rom":"i noraega gajang joayo.","en":"I like this song the most.","vocab":["노래","가장"]},{"kr":"은행에서 돈을 찾았어요.","rom":"eunhaengeseo doneul chajasseoyo.","en":"I withdrew money from the bank.","vocab":["은행","돈을 찾다"]},{"kr":"야채를 매일 먹어요.","rom":"yachaereul maeil meogeoyo.","en":"I eat vegetables every day.","vocab":["야채","매일"]},{"kr":"가족하고 같이 식당에 갔어요.","rom":"gajokhago gachi sikdange gasseoyo.","en":"I went to a restaurant with my family.","vocab":["가족"]},{"kr":"한국 드라마가 재미있어요.","rom":"hanguk deuramaga jaemiisseoyo.","en":"Korean dramas are fun.","vocab":[]},{"kr":"다음 주에 여행을 갈 거예요.","rom":"daeum jue yeohaengeul gal geoyeyo.","en":"Next week I'm going to travel.","vocab":["여행"]}]
